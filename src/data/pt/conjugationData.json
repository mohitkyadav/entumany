{
  "PRON": ["eu", "tu", "ele / ela / você", "nós", "eles / elas / vocês"],
  "TENSES": [
    {"key": "pres",   "pt": "Presente",                "en": "I speak / I'm speaking",              "grp": "now",  "def": true},
    {"key": "prog",   "pt": "Estar a + infinitivo",    "en": "I'm speaking right now (EP)",          "grp": "now",  "def": true},
    {"key": "futp",   "pt": "Futuro com «ir»",         "en": "I'm going to speak",                   "grp": "now",  "def": true},
    {"key": "perf",   "pt": "Pretérito Perfeito",      "en": "I spoke (finished)",                   "grp": "past", "def": true},
    {"key": "imperf", "pt": "Pretérito Imperfeito",    "en": "I used to / was speaking",             "grp": "past", "def": false},
    {"key": "fut",    "pt": "Futuro Simples",          "en": "I will speak (formal)",                "grp": "past", "def": false},
    {"key": "cond",   "pt": "Condicional",             "en": "I would speak",                        "grp": "past", "def": false},
    {"key": "pconj",  "pt": "Presente do Conjuntivo",  "en": "…que eu fale",                         "grp": "conj", "def": false},
    {"key": "iconj",  "pt": "Imperfeito do Conjuntivo","en": "se eu falasse…",                       "grp": "conj", "def": false},
    {"key": "fconj",  "pt": "Futuro do Conjuntivo",    "en": "quando eu falar… (EP)",                "grp": "conj", "def": false}
  ],
  "HINTS": {
    "pres":   "<b>Presente.</b> Habits and current facts. <i>Eu falo português todos os dias.</i>",
    "prog":   "<b>Estar a + infinitivo.</b> Something happening right now. EP uses <i>a + infinitivo</i>, not the «-ndo» gerund: <i>Estou a falar</i> — not «estou falando».",
    "futp":   "<b>Ir + infinitivo.</b> The everyday way to talk about the future. <i>Amanhã vou falar com ela.</i>",
    "perf":   "<b>Pretérito Perfeito.</b> A single completed past action. <i>Ontem falei com o João.</i> (Watch the «nós» accent: <i>falámos</i> = past, <i>falamos</i> = present.)",
    "imperf": "<b>Pretérito Imperfeito.</b> Background, habits, descriptions in the past. <i>Antigamente falava com ele todos os dias.</i>",
    "fut":    "<b>Futuro Simples.</b> Mostly written/formal — speech prefers <i>ir + inf</i>. <i>Falarei consigo amanhã.</i>",
    "cond":   "<b>Condicional.</b> Hypothetical or polite. <i>Eu falaria com ele, mas…</i>",
    "pconj":  "<b>Presente do Conjuntivo.</b> After wishes, doubts, emotions, <i>talvez</i>. <i>Espero que fales com ele. / Talvez fale.</i>",
    "iconj":  "<b>Imperfeito do Conjuntivo.</b> Unreal / counterfactual conditions. <i>Se eu falasse melhor, arranjava emprego.</i>",
    "fconj":  "<b>Futuro do Conjuntivo.</b> Very common in EP — used after <i>quando / se / assim que / enquanto</i> pointing at the future, where English uses the present. <i>Quando falares com ele, diz-lhe.</i>"
  },
